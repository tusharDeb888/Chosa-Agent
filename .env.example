# ─────────────────── Database ───────────────────
POSTGRES_DB=alphahunter
POSTGRES_USER=ahuser
POSTGRES_PASSWORD=ahpass
POSTGRES_PORT=5432

# ─────────────────── Redis ───────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ─────────────────── Backend ───────────────────
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ahuser:ahpass@localhost:5432/alphahunter
DATABASE_URL_SYNC=postgresql://ahuser:ahpass@localhost:5432/alphahunter
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ─────────────────── Market Data ───────────────────
# mock | upstox
MARKET_PROVIDER=mock

# Upstox (optional, required only when MARKET_PROVIDER=upstox)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=

# ─────────────────── LLM ───────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ─────────────────── Embeddings ───────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─────────────────── Agent Control ───────────────────
CONTROL_CHANNEL=agent.control
AGENT_DEFAULT_STATE=PAUSED

# ─────────────────── Stream Configuration ───────────────────
STREAM_RETENTION_TICKS_MAXLEN=50000
STREAM_RETENTION_SIGNALS_MAXLEN=10000
STREAM_RETENTION_DECISIONS_MAXLEN=10000
STREAM_CONSUMER_GROUP=alphahunter-workers
STREAM_BLOCK_MS=5000
STREAM_BATCH_SIZE=10

# ─────────────────── Idempotency ───────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ─────────────────── Policy Defaults ───────────────────
POLICY_MAX_POSITION_CONCENTRATION_PCT=25
POLICY_MAX_DAILY_ACTIONS=20
POLICY_MIN_CONFIDENCE_BUY_SELL=60
POLICY_MAX_EVIDENCE_AGE_HOURS=24

# ─────────────────── SLO Thresholds ───────────────────
SLO_P50_ALERT_LATENCY_MS=1200
SLO_P95_ALERT_LATENCY_MS=3000
SLO_P99_ALERT_LATENCY_MS=5000
SLO_BREACH_WINDOW_COUNT=5

# ─────────────────── Enrichment ───────────────────
SCRAPER_MAX_CONCURRENT=5
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_ALLOWED_DOMAINS=moneycontrol.com,economictimes.com,livemint.com,reuters.com,bloomberg.com

# ─────────────────── Frontend ───────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
